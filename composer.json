{
    "name": "conundrum-codex/binding-engine-vocabulary",
    "description": "Vocabulary builder for Binding Engine",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:Conundrum-Codex/binding-engine-parser.git"
        }
    ],
    "require": {
        "php": "^8.4",
        "conundrum-codex/binding-engine-parser": ">=0.1.0 <1.0.0"
    },
    "autoload": {
        "psr-4": {
            "ConundrumCodex\\BindingEngine\\Vocabulary\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Sam Baynham",
            "email": "sam.baynham@gmail.com"
        }
    ],
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.80",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^4.4",
        "phpstan/phpstan": "^2.1",
        "symfony/var-dumper": "^8.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "scripts": {
        "php-cs:check": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --verbose --sequential",
        "php-cs:fix": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --verbose --sequential",
        "test": "pest",
        "stan": "php -d memory_limit=1G vendor/bin/phpstan analyse"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "homepage": "https://github.com/Conundrum-Codex/binding-engine-vocabulary",
    "support": {
        "issues": "https://github.com/Conundrum-Codex/binding-engine-vocabulary/issues",
        "source": "https://github.com/Conundrum-Codex/binding-engine-vocabularyer"
    }
}
